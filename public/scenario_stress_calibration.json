{
  "_doc": "Phase 2 \u2014 Scenario Stress Calibration. Per-scenario peak-stress values for the indicators feeding the 6 cycle mechanisms. Senior Quant validates / extends each row before producer wires (Phase 2C).",
  "version": "phase2-scope-2026-05-08",
  "framework": "v11 cycle mechanisms",
  "as_of": "2026-05-08",
  "indicators": {
    "cape": {
      "name": "CAPE (Shiller)",
      "mechanism": "valuation",
      "source": "Shiller dataset (Yale)",
      "direction": "high_is_concerning",
      "unit": "ratio"
    },
    "erp": {
      "name": "Equity Risk Premium",
      "mechanism": "valuation",
      "source": "Shiller dataset (1/CAPE - 10y TIPS)",
      "direction": "low_is_concerning",
      "unit": "%"
    },
    "buffett": {
      "name": "Buffett ratio (Wilshire 5000 / GDP)",
      "mechanism": "valuation",
      "source": "Wilshire 5000 / BEA GDP",
      "direction": "high_is_concerning",
      "unit": "%"
    },
    "hy_oas": {
      "name": "HY OAS",
      "mechanism": "credit",
      "source": "ICE BofA via FRED (BAMLH0A0HYM2)",
      "direction": "high_is_concerning",
      "unit": "bps"
    },
    "ig_oas": {
      "name": "IG OAS",
      "mechanism": "credit",
      "source": "ICE BofA via FRED (BAMLC0A0CM)",
      "direction": "high_is_concerning",
      "unit": "bps"
    },
    "ig_hy_ratio": {
      "name": "IG / HY spread ratio",
      "mechanism": "credit",
      "source": "derived (IG OAS / HY OAS)",
      "direction": "low_is_concerning",
      "unit": "ratio"
    },
    "cpff": {
      "name": "Commercial Paper risk premium (CPFF)",
      "mechanism": "funding",
      "source": "FRED (CPFF)",
      "direction": "high_is_concerning",
      "unit": "bps"
    },
    "stlfsi": {
      "name": "St. Louis Fed Financial Stress Index",
      "mechanism": "funding",
      "source": "FRED (STLFSI4)",
      "direction": "high_is_concerning",
      "unit": "std"
    },
    "bank_reserves": {
      "name": "Bank reserves at Fed",
      "mechanism": "funding",
      "source": "FRED (WRESBAL)",
      "direction": "low_is_concerning",
      "unit": "$T"
    },
    "rrp": {
      "name": "Reverse Repo balance",
      "mechanism": "funding",
      "source": "FRED (RRPONTSYD)",
      "direction": "low_is_concerning",
      "unit": "$B"
    },
    "ism_mfg": {
      "name": "ISM Manufacturing PMI",
      "mechanism": "growth",
      "source": "ISM",
      "direction": "low_is_concerning",
      "unit": "index (50=expand)"
    },
    "ism_svc": {
      "name": "ISM Services PMI",
      "mechanism": "growth",
      "source": "ISM",
      "direction": "low_is_concerning",
      "unit": "index (50=expand)"
    },
    "gdpnow": {
      "name": "Atlanta Fed GDPNow",
      "mechanism": "growth",
      "source": "Atlanta Fed",
      "direction": "low_is_concerning",
      "unit": "%"
    },
    "anfci": {
      "name": "Chicago Fed ANFCI",
      "mechanism": "liquidity_policy",
      "source": "FRED (NFCI)",
      "direction": "high_is_concerning",
      "unit": "std"
    },
    "fed_bs_yoy": {
      "name": "Fed Balance Sheet YoY %",
      "mechanism": "liquidity_policy",
      "source": "FRED (WALCL YoY %)",
      "direction": "low_is_concerning",
      "unit": "%"
    },
    "sloos_ci": {
      "name": "SLOOS C&I lending tightening (net %)",
      "mechanism": "liquidity_policy",
      "source": "Fed SLOOS",
      "direction": "high_is_concerning",
      "unit": "%"
    },
    "m2_yoy": {
      "name": "M2 Money Supply YoY %",
      "mechanism": "liquidity_policy",
      "source": "FRED (M2SL YoY)",
      "direction": "low_is_concerning",
      "unit": "%"
    },
    "skew": {
      "name": "CBOE SKEW",
      "mechanism": "positioning_breadth",
      "source": "CBOE",
      "direction": "high_is_concerning",
      "unit": "index"
    },
    "vix": {
      "name": "VIX",
      "mechanism": "positioning_breadth",
      "source": "CBOE",
      "direction": "high_is_concerning",
      "unit": "index"
    },
    "eq_cr_corr": {
      "name": "Equity-credit correlation (60d)",
      "mechanism": "positioning_breadth",
      "source": "derived (S&P vs HYG)",
      "direction": "high_is_concerning",
      "unit": "corr"
    },
    "move": {
      "name": "MOVE Index (Treasury vol)",
      "mechanism": "positioning_breadth",
      "source": "ICE BofA",
      "direction": "high_is_concerning",
      "unit": "index"
    }
  },
