          "as_of": "2008-11-30",
          "source_note": "CAPE bottomed near 13 in Nov 2008 (multpl.com / Shiller data)"
        },
        "erp": {
          "value": 7.5,
          "as_of": "2008-11-30",
          "source_note": "Earnings yield surge from 13\u00d7 P/E + collapsing 10y TIPS"
        },
        "buffett": {
          "value": 58.0,
          "as_of": "2008-Q4",
          "source_note": "Wilshire fell ~50% from 2007 peak; GDP modestly down"
        },
        "hy_oas": {
          "value": 1900,
          "as_of": "2008-12-15",
          "source_note": "FRED BAMLH0A0HYM2 hit 1971 bps Dec 15 2008"
        },
        "ig_oas": {
          "value": 620,
          "as_of": "2008-12-08",
          "source_note": "FRED BAMLC0A0CM peaked ~620 in Dec 2008"
        },
        "ig_hy_ratio": {
          "value": 0.33,
          "as_of": "2008-12-15",
          "source_note": "derived (620/1900)"
        },
        "cpff": {
          "value": 275,
          "as_of": "2008-10-10",
          "source_note": "3M CP-OIS spread spiked >200bps post-Lehman"
        },
        "stlfsi": {
          "value": 7.3,
          "as_of": "2008-10-17",
          "source_note": "FRED STLFSI4 hit 7.32 Oct 2008 (record)"
        },
        "bank_reserves": {
          "value": 0.74,
          "as_of": "2008-12-31",
          "source_note": "WRESBAL ~$740B end-2008 (post-QE1 surge)"
        },
        "rrp": {
          "value": 0,
          "as_of": "2008-12-31",
          "source_note": "RRP facility didn't exist yet (launched 2013)"
        },
        "ism_mfg": {
          "value": 32.4,
          "as_of": "2008-12-31",
          "source_note": "Dec 2008 ISM Mfg = 32.4 (cycle low)"
        },
        "ism_svc": {
          "value": 37.8,
          "as_of": "2008-11-30",
          "source_note": "Nov 2008 ISM Services = 37.8 (record low at time)"
        },
        "gdpnow": {
          "value": -8.0,
          "as_of": "2008-Q4",
          "source_note": "Q4 2008 advance GDP -8.4% (revised; GDPNow not live until 2014, used realized print as proxy)"
        },
        "anfci": {
          "value": 4.5,
          "as_of": "2008-10-31",
          "source_note": "FRED NFCI peaked >4.0 in Oct 2008"
        },
        "fed_bs_yoy": {
          "value": 140,
          "as_of": "2008-12-31",
          "source_note": "WALCL grew from $0.9T to $2.2T over 2008 (~140% YoY)"
        },
        "sloos_ci": {
          "value": 83,
          "as_of": "2008-Q4",
          "source_note": "Q4 2008 SLOOS net % tightening C&I = 83.6"
        },
        "m2_yoy": {
          "value": 9.5,
          "as_of": "2008-12-31",
          "source_note": "M2 grew accelerating into year-end"
        },
        "skew": {
          "value": 118,
          "as_of": "2008-10-15",
          "source_note": "CBOE SKEW elevated 115-125 range Oct-Nov 2008"
        },
        "vix": {
          "value": 80.9,
          "as_of": "2008-11-20",
          "source_note": "VIX intraday 80.86 Nov 20 2008 (record high)"
        },
        "eq_cr_corr": {
          "value": 0.85,
          "as_of": "2008-Q4",
          "source_note": "Equity-credit corr near 0.85 at GFC peak"
        },
        "move": {
          "value": 260,
          "as_of": "2008-10-31",
          "source_note": "MOVE peaked 260+ Oct 2008"
        }
      }
    },
