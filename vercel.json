{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/options-mark-batch",
      "schedule": "30 20 * * 1-5"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|favicon|.*\\.(?:js|css|json|png|svg|ico|jpg|jpeg|webp|map|woff2?|ttf|otf|eot|txt|xml|webmanifest|html)).*)",
      "destination": "/index.html"
    }
  ]
}

