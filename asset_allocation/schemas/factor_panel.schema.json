{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://macrotilt.com/schemas/factor_panel.schema.json",
  "title": "Factor Panel — unified macro factor data",
  "description": "Unified factor panel produced by acquisition.py. Each factor has its source, cadence, and time series of (date, value) points.",
  "type": "object",
  "required": ["schema_version", "pulled_at", "factors"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v10.0"
    },
    "pulled_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this panel was assembled."
    },
    "source_run_id": {
      "type": "string",
      "description": "Acquisition run ID for traceability."
    },
    "factors": {
      "type": "object",
      "description": "Map of factor_id -> factor metadata + time series.",
      "minProperties": 20,
      "additionalProperties": {
        "type": "object",
        "required": ["source", "cadence", "unit", "points"],
        "properties": {
          "source": {
            "type": "string",
            "description": "FRED:SERIES_ID or Yahoo:TICKER or Computed:FORMULA",
            "pattern": "^(FRED|Yahoo|Computed|StaticReference):.+"
          },
          "cadence": {
            "type": "string",
            "enum": ["D", "W", "M", "Q", "I"],
            "description": "Daily / Weekly / Monthly / Quarterly / Irregular"
          },
          "unit": {
            "type": "string",
            "description": "Free-text unit description (bps, %, level, ratio, etc.)"
          },
          "min_value": {
            "type": "number",
            "description": "Sanity-check lower bound — values below this fail validation"
          },
          "max_value": {
            "type": "number",
            "description": "Sanity-check upper bound — values above this fail validation"
          },
          "max_mom_zscore": {
            "type": "number",
            "default": 5.0,
            "description": "Anomaly threshold for month-over-month change in z-score units"
          },
          "expected_lag_days": {
            "type": "integer",
            "minimum": 0,
            "description": "Maximum acceptable lag between observation date and pull date"
          },
          "points": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "prefixItems": [
                { "type": "string", "format": "date" },
                { "type": ["number", "null"] }
              ]
            },
            "description": "[[YYYY-MM-DD, numeric_value], ...] sorted ascending by date"
          }
        }
      }
    }
  },
  "additionalProperties": false
}
